<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cta.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>__CTA_DIR__/venv/bin/python3</string>
        <string>__CTA_DIR__/agent.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__CTA_DIR__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__HOME__/.cta/cta.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/.cta/cta.err</string>
</dict>
</plist>
